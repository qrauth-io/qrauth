# Database
DATABASE_URL=postgresql://qrauth:qrauth_dev_password@localhost:5432/qrauth_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Key Management System
KMS_PROVIDER=local
ECDSA_PRIVATE_KEY_PATH=/etc/qrauth/ecdsa_private.pem

# Authentication
VISUAL_PROOF_SECRET=your-visual-proof-secret-key-here-min-32-chars

# WebAuthn Configuration
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=QRAuth Platform

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=qrauth
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@example.com

# Application
NODE_ENV=development
LOG_LEVEL=debug
