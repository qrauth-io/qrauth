{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "KMS_PROVIDER",
    "ECDSA_PRIVATE_KEY_PATH",
    "VISUAL_PROOF_SECRET",
    "WEBAUTHN_ORIGIN",
    "WEBAUTHN_RP_ID",
    "WEBAUTHN_RP_NAME",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ZONE_ID",
    "CLICKHOUSE_HOST",
    "CLICKHOUSE_PORT",
    "CLICKHOUSE_DATABASE",
    "STRIPE_SECRET_KEY",
    "STRIPE_PUBLISHABLE_KEY",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "SMTP_FROM_ADDRESS"
  ],
  "pipeline": {
    "typecheck": {
      "outputs": [],
      "cache": false
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": false
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "inputs": ["src/**", "tsconfig.json", "next.config.js", "webpack.config.js"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false
    }
  }
}
